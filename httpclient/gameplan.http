@baseUrl = {{baseUrl}}
@token = {{token}}

### Init a new season (default mode: TEN_MINUTES_FROM_NOW)
POST {{baseUrl}}/gameplans/init
Authorization: Bearer {{token}}
Accept: application/json

### Init season: 1 round per day (trainings + game) starting from a France day, game at 20:00 Europe/Paris
POST {{baseUrl}}/gameplans/init
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "mode": "DAILY_MATCH_AND_TRAINING_FROM_DAY",
  "startDay": "2026-03-30"
}

### Init season: 1 round every 10 minutes starting now
POST {{baseUrl}}/gameplans/init
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "mode": "TEN_MINUTES_FROM_NOW"
}

### Init season: 1 round per day starting a month ago, then replay all events immediately
POST {{baseUrl}}/gameplans/init
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "mode": "DAILY_FROM_MONTH_AGO_REPLAY"
}

### Get a gameplan by id
GET {{baseUrl}}/gameplans/38920538-a4cc-4ca8-b071-a0550fd21d2b
Authorization: Bearer {{token}}
Accept: application/json

> {%
    // Use the response as a baseline for the update request below.
    client.global.set("gamePlanDTO", JSON.stringify(response.body, null, 2));
%}


### Get next upcoming gameplan for a club
GET {{baseUrl}}/gameplans/club/<clubId>
Authorization: Bearer {{token}}
Accept: application/json

> {%
  // Use the response as a baseline for the update request below.
  client.global.set("gamePlanDTO", JSON.stringify(response.body, null, 2));
%}

### Update a gameplan (start from previous GET response)
POST {{baseUrl}}/gameplans
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{{gamePlanDTO}}

### Update a gameplan and apply it to all future unplayed gameplans for the same owner team
POST {{baseUrl}}/gameplans/apply-to-upcoming
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{{gamePlanDTO}}
