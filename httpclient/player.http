  "leadership": 85
}

### Récupérer un joueur par son ID
GET http://localhost:8080/players/1f5f56d4-116e-4865-ae21-e243377b2a19
Accept: application/json

### Supprimer un joueur par son ID
DELETE http://localhost:8080/players/1

### Supprimer TOUS les joueurs
DELETE http://localhost:8080/players